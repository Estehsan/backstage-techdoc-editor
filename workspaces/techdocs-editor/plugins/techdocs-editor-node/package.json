{
  "name": "@estehsaan/backstage-plugin-techdocs-editor-node",
  "version": "1.0.2",
  "description": "Node library that defines extension points for custom TechDocs editor VCS providers",
  "backstage": {
    "role": "node-library",
    "pluginId": "techdocs-editor",
    "pluginPackages": [
      "@estehsaan/backstage-plugin-techdocs-editor",
      "@estehsaan/backstage-plugin-techdocs-editor-backend",
      "@estehsaan/backstage-plugin-techdocs-editor-common",
      "@estehsaan/backstage-plugin-techdocs-editor-node",
      "@estehsaan/backstage-plugin-techdocs-editor-react"
    ]
  },
  "keywords": [
    "backstage",
    "backstage-plugin",
    "techdocs",
    "editor",
    "node",
    "vcs",
    "developer-portal"
  ],
  "homepage": "https://github.com/Estehsan/backstage-techdoc-editor/tree/main/workspaces/techdocs-editor/plugins/techdocs-editor-node#readme",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      },
      "./package.json": "./package.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Estehsan/backstage-techdoc-editor",
    "directory": "workspaces/techdocs-editor/plugins/techdocs-editor-node"
  },
  "bugs": {
    "url": "https://github.com/Estehsan/backstage-techdoc-editor/issues"
  },
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "package.json": [
        "package.json"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "lint": "backstage-cli package lint",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "test": "backstage-cli package test"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "^1.7.0",
    "@estehsaan/backstage-plugin-techdocs-editor-common": "workspace:^"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0"
  }
}
