{
  "name": "estehsan-backstage-techdocs-editor-plugins",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.8.1",
  "engines": {
    "node": "22 || 24"
  },
  "workspaces": [
    "workspaces/*/plugins/*"
  ],
  "scripts": {
    "build:api-reports": "yarn tsc --skipLibCheck && yarn build:api-reports:only",
    "build:api-reports:only": "backstage-repo-tools api-reports -o ae-wrong-input-file-type,ae-undocumented --validate-release-tags",
    "build:all": "yarn tsc -p workspaces/techdocs-editor/tsconfig.json && yarn workspaces foreach --all --topological-dev --no-private run build",
    "clean": "yarn workspaces foreach --all --parallel run clean",
    "fix": "yarn backstage-cli repo fix",
    "lint": "yarn backstage-cli repo lint",
    "new": "backstage-cli new --scope @estehsaan",
    "prepare": "husky",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test": "yarn backstage-cli repo test",
    "tsc": "tsc"
  },
  "peerDependencies": {
    "react": "^18.0.2",
    "react-dom": "^18.0.2",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@backstage/cli-defaults": "^0.1.0",
    "@backstage/repo-tools": "^0.17.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/react": "^18.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.0",
    "semantic-release": "^24.0.0",
    "semantic-release-yarn": "^3.0.0",
    "typescript": "~5.4.0"
  },
  "resolutions": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.2",
    "react-dom": "^18.0.2",
    "@material-ui/core": "4.12.4",
    "@material-ui/styles": "4.11.5",
    "@material-ui/icons": "4.11.3",
    "@backstage/core-components": "0.18.8"
  }
}
