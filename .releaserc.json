{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    ["semantic-release-yarn", { "npmPublish": true }],
    "@semantic-release/github",
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "workspaces/techdocs-editor/plugins/techdocs-editor/package.json",
          "workspaces/techdocs-editor/plugins/techdocs-editor-backend/package.json",
          "workspaces/techdocs-editor/plugins/techdocs-editor-common/package.json",
          "workspaces/techdocs-editor/plugins/techdocs-editor-node/package.json",
          "workspaces/techdocs-editor/plugins/techdocs-editor-react/package.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
